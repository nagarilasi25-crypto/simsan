{
  "entities": {
    "Santri": {
      "title": "Santri",
      "description": "Data Induk Santri Pesantren",
      "type": "object",
      "properties": {
        "nis": { "type": "string", "maxLength": 50 },
        "nik": { "type": "string", "maxLength": 50 },
        "nama": { "type": "string", "maxLength": 100 },
        "jenisKelamin": { "type": "string", "enum": ["L", "P"] },
        "tempatLahir": { "type": "string", "maxLength": 100 },
        "tanggalLahir": { "type": "string", "maxLength": 20 },
        "jenjang": { "type": "string", "maxLength": 50 },
        "kelas": { "type": "string", "maxLength": 50 },
        "halaqah": { "type": "string", "maxLength": 100 },
        "guruPembimbing": { "type": "string", "maxLength": 100 },
        "nagari": { "type": "string", "maxLength": 100 },
        "kecamatan": { "type": "string", "maxLength": 100 },
        "status": { "type": "string", "enum": ["Aktif", "Non-Aktif", "Alumni", "Cuti", "Mutasi"] },
        "createdAt": { "type": "string", "maxLength": 50 }
      },
      "required": ["nis", "nama", "jenjang", "status"]
    },
    "Setting": {
      "title": "Setting",
      "description": "Pengaturan Sistem SIMSAN",
      "type": "object",
      "properties": {
        "namaLembaga": { "type": "string", "maxLength": 100 },
        "prefixNis": { "type": "string", "maxLength": 10 },
        "tahunAjaranAktif": { "type": "string", "maxLength": 20 },
        "alamat": { "type": "string", "maxLength": 200 }
      }
    },
    "AuditLog": {
      "title": "AuditLog",
      "description": "Log Aktivitas SIMSAN",
      "type": "object",
      "properties": {
        "action": { "type": "string", "maxLength": 100 },
        "target": { "type": "string", "maxLength": 200 },
        "userName": { "type": "string", "maxLength": 100 },
        "role": { "type": "string", "maxLength": 50 },
        "timestamp": { "type": "string", "maxLength": 50 }
      }
    }
  },
  "firestore": {
    "/santri/{santriId}": {
      "schema": { "$ref": "#/entities/Santri" },
      "description": "Koleksi data santri"
    },
    "/settings/{settingId}": {
      "schema": { "$ref": "#/entities/Setting" },
      "description": "Koleksi pengaturan sistem"
    },
    "/audit_logs/{logId}": {
      "schema": { "$ref": "#/entities/AuditLog" },
      "description": "Koleksi audit logs"
    }
  }
}
